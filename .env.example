# Frontend no longer talks to Supabase; only the backend does. You do NOT need VITE_SUPABASE_* for the app to run.
# (Optional: leave unset. If you add them, they are not used by the frontend.)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Backend uses Supabase to read users table (password_hash, etc.). Service role required for auth.
# Get both from Supabase Dashboard → Project Settings → API (URL + service_role secret key).
SUPABASE_URL=https://your-project-ref.supabase.co
# Required: paste your service_role secret here (starts with eyJ... or sb_secret_...). Do not use anon key in production.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT signing secret for custom auth (required; use a long random string in production)
JWT_SECRET=your-jwt-secret

# Optional: JWT expiry (default 7d)
# JWT_EXPIRES_IN=7d

# Okta SSO
# Backend (Vercel serverless) and frontend (Vite) both need these.
# Use tenant domain (no -admin), e.g. https://dev-123456.okta.com
# OKTA_DOMAIN=https://dev-123456.okta.com
# Org Authorization Server issuer (from .well-known/openid-configuration "issuer")
# Example: https://brisa.okta-emea.com
# OKTA_ISSUER=https://dev-123456.okta.com
# OKTA_CLIENT_ID=0oa...
# Optional for confidential clients (e.g. web app integrations):
# OKTA_CLIENT_SECRET=
# Optional: enable to auto-create unknown Okta users as volunteers.
# OKTA_AUTO_PROVISION_UNKNOWN_USERS=false
# Required when OKTA_AUTO_PROVISION_UNKNOWN_USERS=true.
# Must be a valid companies.id UUID.
# OKTA_DEFAULT_COMPANY_ID=
# VITE_OKTA_DOMAIN=https://dev-123456.okta.com
# VITE_OKTA_ISSUER=https://dev-123456.okta.com
# VITE_OKTA_CLIENT_ID=0oa...

# Optional: backend API base URL. Leave UNSET so the app uses same origin (Vite proxies /api to the local API).
# VITE_API_URL=

# Google Analytics 4 (frontend)
# Set your measurement ID to enable tracking in production builds.
# Example: VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=
# Optional: keep false/empty to avoid dev traffic in GA.
# VITE_GA_ENABLE_IN_DEV=false

# Resend (transactional email delivery for invites/recovery)
# RESEND_API_KEY=re_xxx
# Optional; defaults to "Coompass <onboarding@resend.dev>"
# RESEND_FROM_EMAIL=Coompass <onboarding@resend.dev>
# Optional; mission-related emails CC recipient. Leave unset to disable CC (e.g. in staging).
# MISSION_EMAIL_CC=

# Local login: run the API in a separate terminal so /api/auth/login is available:
#   Terminal 1: npm run dev:api   (listens on http://localhost:3001)
#   Terminal 2: npm run dev       (Vite proxies /api to 3001)
# Without SUPABASE_* set, the API allows dev login: email user10@coompass.ai, any password.

# Database URL for running seeds (Supabase Dashboard → Settings → Database → Connection string URI)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Optional: PostgreSQL (Sequelize / local DB)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=coompass
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_SSL=false
